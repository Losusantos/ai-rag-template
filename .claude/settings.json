{
  "permissions": {
    "allow": [
      "Skill(api-design)",
      "Skill(architecture-design)",
      "Skill(database-migrations)",
      "Skill(deployment-patterns)",
      "Skill(development-guidelines)",
      "Skill(functional-design)",
      "Skill(glossary-creation)",
      "Skill(postgres-patterns)",
      "Skill(prd-writing)",
      "Skill(repository-structure)",
      "Skill(security-review)",
      "Skill(security-scan)",
      "Skill(skill-stocktake)",
      "Skill(steering)",
      "Skill(tdd-workflow)",
      "Skill(verification-loop)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.development)",
      "Read(.env.development.local)",
      "Read(.env.production)",
      "Read(.env.production.local)",
      "Read(.env.test)",
      "Read(.env.test.local)",
      "Edit(.env)",
      "Edit(.env.local)",
      "Edit(.env.development)",
      "Edit(.env.development.local)",
      "Edit(.env.production)",
      "Edit(.env.production.local)",
      "Edit(.env.test)",
      "Edit(.env.test.local)",
      "Write(.env)",
      "Write(.env.local)",
      "Write(.env.development)",
      "Write(.env.development.local)",
      "Write(.env.production)",
      "Write(.env.production.local)",
      "Write(.env.test)",
      "Write(.env.test.local)",
      "Read(.claude/.credentials.json)",
      "Edit(.claude/.credentials.json)",
      "Write(.claude/.credentials.json)",
      "Read(**/secrets.json)",
      "Edit(**/secrets.json)",
      "Write(**/secrets.json)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(sudo *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fdx *)",
      "Bash(dotnet nuget push *)",
      "Bash(chmod 777 *)",
      "Bash(ssh *)",
      "Bash(* > /dev/*)"
    ],
    "ask": [
      "Bash(dotnet add package *)",
      "Bash(dotnet remove package *)",
      "Bash(dotnet tool install *)",
      "Bash(git push *)",
      "Bash(git commit *)",
      "Bash(git rebase *)",
      "Bash(git merge *)",
      "Bash(curl *)",
      "Bash(wget *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'CMD=$(echo \"$CLAUDE_TOOL_INPUT\" | python3 -c \"import sys,json; d=json.load(sys.stdin); print(d.get(\\\"command\\\",\\\"\\\"))\" 2>/dev/null); for PAT in \"dd if=\" \"mkfs\" \"fdisk\" \"parted\" \"shred\" \"> /dev/sd\" \"> /dev/nvme\" \"chmod -R 777\" \"chown -R\"; do echo \"$CMD\" | grep -qF \"$PAT\" && echo \"[Security] Blocked dangerous pattern: $PAT\" >&2 && exit 2; done; exit 0'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'cd \"$(git rev-parse --show-toplevel 2>/dev/null || echo .)\" && git diff --name-only 2>/dev/null | xargs grep -l -E \"(api_key|secret|password|token)\\s*=\\s*\\S\" 2>/dev/null | while read f; do echo \"[Security] WARNING: possible secret in modified file: $f\" >&2; done; exit 0'"
          }
        ]
      }
    ]
  }
}
